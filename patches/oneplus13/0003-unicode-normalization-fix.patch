From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OnePlus13 KernelBuilder <noreply@users.noreply.github.com>
Date: Tue, 14 Jul 2026 00:00:00 +0700
Subject: [PATCH] unicode: rebase normalization bypass fix onto OnePlus 6.6

Upstream-patch: WildKernels/kernel_patches@2ee34500cb4c3ee954ba36090e11f6ff08b3ec2f/common/unicode_bypass_fix_6.1+.patch
Rebased-on: OnePlusOSS/android_kernel_common_oneplus_sm8750@9920459dfb0080dd8a81c41d95701483857f804a

diff --git a/fs/unicode/utf8-norm.c b/fs/unicode/utf8-norm.c
index 768f8ab448b8..b10932d1f527 100644
--- a/fs/unicode/utf8-norm.c
+++ b/fs/unicode/utf8-norm.c
@@ -513,21 +513,21 @@ int utf8byte(struct utf8cursor *u8c)
 		    u8c->um->ntab[u8c->n]->maxage) {
 			ccc = STOPPER;
 		} else if (ccc == DECOMPOSE) {
-			u8c->len -= utf8clen(u8c->s);
-			u8c->p = u8c->s + utf8clen(u8c->s);
-			u8c->s = LEAF_STR(leaf);
-			/* Empty decomposition implies CCC 0. */
-			if (*u8c->s == '\0') {
-				if (u8c->ccc == STOPPER)
-					continue;
+			// Check if the decomposition result is empty (e.g., zero-width space)
+			if (*LEAF_STR(leaf) == '\0') {
 				ccc = STOPPER;
-				goto ccc_mismatch;
+			} else {
+				// Pointer movement and state modification are performed only when it is confirmed that the character is a normal character that needs to be decomposed.
+				u8c->len -= utf8clen(u8c->s);
+				u8c->p = u8c->s + utf8clen(u8c->s);
+				u8c->s = LEAF_STR(leaf);
+
+				// Proceed to the next level of searching
+				leaf = utf8lookup(u8c->um, u8c->n, u8c->hangul, u8c->s);
+				if (!leaf)
+					return -1;
+				ccc = LEAF_CCC(leaf);
 			}
-
-			leaf = utf8lookup(u8c->um, u8c->n, u8c->hangul, u8c->s);
-			if (!leaf)
-				return -1;
-			ccc = LEAF_CCC(leaf);
 		}
 
 		/*

