# In-tree wireless modules. These must be built against the matching
# common-kernel Module.symvers for the selected manifest.
CONFIG_WLAN_VENDOR_REALTEK=y
# CONFIG_RTW88 is not set
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_CRYPTO_MICHAEL_MIC=m
CONFIG_WLAN_VENDOR_ATH=y
CONFIG_ATH_COMMON=m
CONFIG_ATH9K=m
CONFIG_ATH9K_HW=m
CONFIG_ATH9K_HTC=m
CONFIG_ATH9K_COMMON=m
CONFIG_ATH10K=m
CONFIG_ATH10K_USB=m
CONFIG_ATH11K=m
CONFIG_ATH11K_PCI=m
CONFIG_WLAN_VENDOR_MEDIATEK=y
CONFIG_MT7601U=m
CONFIG_MT76_CORE=m
CONFIG_MT76_USB=m
CONFIG_MT76x02_LIB=m
CONFIG_MT76x02_USB=m
CONFIG_MT76_CONNAC_LIB=m
CONFIG_MT7603E=m
CONFIG_MT76x2_COMMON=m
CONFIG_MT76x2U=m
CONFIG_MT76x0_COMMON=m
CONFIG_MT76x0U=m
CONFIG_MT7615_COMMON=m
CONFIG_MT7615E=m
CONFIG_MT7663U=m
CONFIG_MT7915E=m
CONFIG_MT7921_COMMON=m
CONFIG_MT7921E=m
CONFIG_MT7921U=m
CONFIG_MAC80211_LEDS=y
CONFIG_CAN_SLCAN=m
CONFIG_MEMKERNEL=m
