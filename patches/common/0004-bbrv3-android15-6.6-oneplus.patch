+/* TCP BBR congestion control bbr_phase as reported in netlink/ss stats. */
+enum tcp_bbr_phase {
+	BBR_PHASE_INVALID			= 0,
+	BBR_PHASE_STARTUP			= 1,
+	BBR_PHASE_DRAIN				= 2,
+	BBR_PHASE_PROBE_RTT			= 3,
+	BBR_PHASE_PROBE_BW_UP		= 4,
+	BBR_PHASE_PROBE_BW_DOWN		= 5,
+	BBR_PHASE_PROBE_BW_CRUISE	= 6,
