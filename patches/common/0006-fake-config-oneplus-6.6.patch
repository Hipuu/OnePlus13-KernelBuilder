From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OnePlus13 KernelBuilder <noreply@users.noreply.github.com>
Date: Tue, 14 Jul 2026 00:00:00 +0700
Subject: [PATCH] kbuild: rebase fake proc config support onto OnePlus 6.6

Rebase the pinned WildKernels fake-config implementation onto the locked
OnePlus Android 15 6.6 Kbuild layout.

Upstream-patch: WildKernels/kernel_patches@2ee34500cb4c3ee954ba36090e11f6ff08b3ec2f/common/fake_config.patch
Rebased-on: OnePlusOSS/android_kernel_common_oneplus_sm8750@9920459dfb0080dd8a81c41d95701483857f804a

diff --git a/kernel/Makefile b/kernel/Makefile
index dd97eb4a074d..719615a88b3f 100644
--- a/kernel/Makefile
+++ b/kernel/Makefile
@@ -145,7 +145,8 @@ KCOV_INSTRUMENT_stackleak.o := n
 
 obj-$(CONFIG_SCF_TORTURE_TEST) += scftorture.o
 
-$(obj)/configs.o: $(obj)/config_data.gz
+CFLAGS_configs.o += -D__FORCE_REBUILD__="$(shell date +%s)"
+$(obj)/configs.o: $(obj)/config_data.gz FORCE
 
 targets += config_data config_data.gz
 $(obj)/config_data.gz: $(obj)/config_data FORCE
@@ -153,7 +154,16 @@ $(obj)/config_data.gz: $(obj)/config_data FORCE
 
 filechk_cat = cat $<
 
-$(obj)/config_data: $(KCONFIG_CONFIG) FORCE
+CONFIG_FAKE_DISABLE ?=
+export CONFIG_FAKE_DISABLE
+CONFIG_OPTIONS_LIST := $(strip $(CONFIG_FAKE_DISABLE))
+
+# Dynamically point Kbuild to a pre-stripped file instead of the raw root config
+ifneq ($(CONFIG_OPTIONS_LIST),)
+KCONFIG_CONFIG_PATCHED := $(shell sed $(foreach opt,$(CONFIG_OPTIONS_LIST),-e 's|^$(opt)=.*|\# $(opt) is not set|') $(KCONFIG_CONFIG) > .config.patched && echo ".config.patched")
+endif
+
+$(obj)/config_data: $(if $(KCONFIG_CONFIG_PATCHED),$(KCONFIG_CONFIG_PATCHED),$(KCONFIG_CONFIG)) FORCE
 	$(call filechk,cat)
 
 $(obj)/kheaders.o: $(obj)/kheaders_data.tar.xz

