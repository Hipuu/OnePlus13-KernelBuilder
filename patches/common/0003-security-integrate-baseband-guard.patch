From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OnePlus13 KernelBuilder <noreply@users.noreply.github.com>
Date: Tue, 14 Jul 2026 00:00:00 +0700
Subject: [PATCH] security: integrate pinned Baseband Guard sources

Wire the source-only Baseband Guard copy into the Android 15 6.6 security
build, expose its Kconfig, and include its LSM in every stock default ordering.
The actual implementation remains in the separately locked GPL-2.0-only
Baseband Guard dependency.
---
 security/Kconfig  | 12 +++++++-----
 security/Makefile |  1 +
 2 files changed, 8 insertions(+), 5 deletions(-)

diff --git a/security/Kconfig b/security/Kconfig
index 52c9af08f..6fc2f596a 100644
--- a/security/Kconfig
+++ b/security/Kconfig
@@ -287,9 +287,9 @@ config LSM
 	string "Ordered list of enabled LSMs"
-	default "landlock,lockdown,yama,loadpin,safesetid,smack,selinux,tomoyo,apparmor,bpf" if DEFAULT_SECURITY_SMACK
-	default "landlock,lockdown,yama,loadpin,safesetid,apparmor,selinux,smack,tomoyo,bpf" if DEFAULT_SECURITY_APPARMOR
-	default "landlock,lockdown,yama,loadpin,safesetid,tomoyo,bpf" if DEFAULT_SECURITY_TOMOYO
-	default "landlock,lockdown,yama,loadpin,safesetid,bpf" if DEFAULT_SECURITY_DAC
-	default "landlock,lockdown,yama,loadpin,safesetid,selinux,smack,tomoyo,apparmor,bpf"
+	default "landlock,lockdown,yama,loadpin,safesetid,smack,selinux,baseband_guard,tomoyo,apparmor,bpf" if DEFAULT_SECURITY_SMACK
+	default "landlock,lockdown,yama,loadpin,safesetid,apparmor,selinux,baseband_guard,smack,tomoyo,bpf" if DEFAULT_SECURITY_APPARMOR
+	default "landlock,lockdown,yama,loadpin,safesetid,tomoyo,bpf,baseband_guard" if DEFAULT_SECURITY_TOMOYO
+	default "landlock,lockdown,yama,loadpin,safesetid,bpf,baseband_guard" if DEFAULT_SECURITY_DAC
+	default "landlock,lockdown,yama,loadpin,safesetid,selinux,baseband_guard,smack,tomoyo,apparmor,bpf"
 	help
 	  A comma-separated list of LSMs, in initialization order.
 	  Any LSMs left off this list, except for those with order
@@ -303,6 +303,8 @@ config LSM
 
 	  If unsure, leave this as the default.
 
+source "security/baseband-guard/Kconfig"
+
 source "security/Kconfig.hardening"
 
 endmenu
diff --git a/security/Makefile b/security/Makefile
index 18121f8f8..fb0e7fbf8 100644
--- a/security/Makefile
+++ b/security/Makefile
@@ -25,6 +25,7 @@ obj-$(CONFIG_SECURITY_LOCKDOWN_LSM)	+= lockdown/
 obj-$(CONFIG_CGROUPS)			+= device_cgroup.o
 obj-$(CONFIG_BPF_LSM)			+= bpf/
 obj-$(CONFIG_SECURITY_LANDLOCK)		+= landlock/
+obj-$(CONFIG_BBG)			+= baseband-guard/
 
 # Object integrity file lists
 obj-$(CONFIG_INTEGRITY)			+= integrity/
-- 
2.50.1
